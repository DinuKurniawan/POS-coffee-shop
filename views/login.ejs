<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Masuk Kasir - POS Kedai Kopi</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-indigo-500 to-purple-600 min-h-screen flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-md">
        <div class="text-center mb-8">
            <div class="text-6xl mb-4">☕</div>
            <h1 class="text-3xl font-bold text-gray-800 mb-2">POS Kedai Kopi</h1>
            <p class="text-gray-600">Masukkan nama kasir untuk memulai</p>
        </div>
        
        <form method="POST" action="/login" class="space-y-6">
            <div>
                <label for="cashierName" class="block text-sm font-semibold text-gray-700 mb-2">
                    Nama Kasir
                </label>
                <input 
                    type="text" 
                    id="cashierName" 
                    name="cashierName" 
                    required
                    autofocus
                    placeholder="Contoh: Andi"
                    class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-indigo-500 text-lg"
                >
            </div>
            
            <button 
                type="submit" 
                class="w-full bg-indigo-600 text-white py-3 rounded-lg font-semibold text-lg hover:bg-indigo-700 transition shadow-lg hover:shadow-xl"
            >
                Mulai Sesi
            </button>
        </form>
        
        <div class="mt-6 text-center text-sm text-gray-500">
            <p>Sesi login berlaku selama 24 jam</p>
        </div>
    </div>
</body>
</html>
