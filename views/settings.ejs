<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pengaturan Pembayaran - POS Kedai Kopi</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
    <%- include('partials/header') %>

    <div class="container mx-auto p-4 space-y-6">
        <div class="bg-white rounded-xl shadow-lg p-6">
            <h2 class="text-3xl font-bold text-gray-800 mb-2">Pengaturan Pembayaran</h2>
            <p class="text-gray-600">Kelola PPN dan rekening bank kedai kopi Anda.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="bg-white rounded-xl shadow-lg p-6 lg:col-span-1">
                <h3 class="text-xl font-bold text-gray-800 mb-4">Pengaturan PPN</h3>
                <form id="vatForm" class="space-y-4">
                    <div>
                        <label for="vatRateInput" class="block text-sm font-semibold text-gray-700 mb-2">Tarif PPN (%)</label>
                        <input id="vatRateInput" name="vatRate" type="number" min="0" max="100" step="0.1" value="<%= settings.vatRate %>" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    </div>
                    <p class="text-sm text-gray-500">PPN ini akan dipakai otomatis pada semua transaksi baru.</p>
                    <button type="submit" class="w-full bg-indigo-600 text-white py-2 rounded-lg font-semibold hover:bg-indigo-700 transition">
                        Simpan PPN
                    </button>
                </form>
            </div>

            <div class="bg-white rounded-xl shadow-lg p-6 lg:col-span-2">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-xl font-bold text-gray-800">Rekening Bank</h3>
                    <button id="showBankFormBtn" type="button" class="bg-green-600 text-white px-4 py-2 rounded-lg font-semibold hover:bg-green-700 transition">
                        + Tambah Rekening
                    </button>
                </div>

                <div id="bankFormContainer" class="hidden bg-gray-50 border border-gray-200 rounded-lg p-4 mb-4">
                    <h4 id="bankFormTitle" class="text-lg font-bold text-gray-800 mb-3">Tambah Rekening Bank</h4>
                    <form id="bankForm" class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        <input type="hidden" id="bankId" value="">

                        <div>
                            <label for="bankName" class="block text-sm font-semibold text-gray-700 mb-1">Nama Bank</label>
                            <input id="bankName" list="bankList" type="text" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500">
                            <datalist id="bankList">
                                <option value="Bank Central Asia (BCA)"></option>
                                <option value="Bank Mandiri"></option>
                                <option value="Bank Rakyat Indonesia (BRI)"></option>
                                <option value="Bank Negara Indonesia (BNI)"></option>
                                <option value="Bank Syariah Indonesia (BSI)"></option>
                                <option value="CIMB Niaga"></option>
                                <option value="Permata Bank"></option>
                                <option value="Danamon"></option>
                                <option value="Panin Bank"></option>
                                <option value="OCBC NISP"></option>
                            </datalist>
                        </div>

                        <div>
                            <label for="accountNumber" class="block text-sm font-semibold text-gray-700 mb-1">Nomor Rekening</label>
                            <input id="accountNumber" type="text" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500">
                        </div>

                        <div>
                            <label for="accountHolder" class="block text-sm font-semibold text-gray-700 mb-1">Nama Pemilik Rekening</label>
                            <input id="accountHolder" type="text" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500">
                        </div>

                        <div>
                            <label for="branch" class="block text-sm font-semibold text-gray-700 mb-1">Cabang (Opsional)</label>
                            <input id="branch" type="text" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500">
                        </div>

                        <div class="md:col-span-2 flex gap-2 pt-1">
                            <button type="submit" class="bg-indigo-600 text-white px-4 py-2 rounded-lg font-semibold hover:bg-indigo-700 transition">
                                Simpan Rekening
                            </button>
                            <button id="cancelBankFormBtn" type="button" class="bg-gray-300 text-gray-700 px-4 py-2 rounded-lg font-semibold hover:bg-gray-400 transition">
                                Batal
                            </button>
                        </div>
                    </form>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-gray-100 text-gray-700">
                                <th class="px-4 py-3 text-left font-semibold">Bank</th>
                                <th class="px-4 py-3 text-left font-semibold">No. Rekening</th>
                                <th class="px-4 py-3 text-left font-semibold">Pemilik</th>
                                <th class="px-4 py-3 text-left font-semibold">Cabang</th>
                                <th class="px-4 py-3 text-center font-semibold">Aksi</th>
                            </tr>
                        </thead>
                        <tbody id="bankTableBody">
                            <% if (settings.bankAccounts.length === 0) { %>
                                <tr>
                                    <td colspan="5" class="px-4 py-8 text-center text-gray-500">Belum ada rekening bank. Tambahkan rekening untuk pembayaran transfer.</td>
                                </tr>
                            <% } else { %>
                                <% settings.bankAccounts.forEach(account => { %>
                                    <tr class="border-b border-gray-200">
                                        <td class="px-4 py-3 font-semibold text-gray-800"><%= account.bankName %></td>
                                        <td class="px-4 py-3 text-gray-700"><%= account.accountNumber %></td>
                                        <td class="px-4 py-3 text-gray-700"><%= account.accountHolder %></td>
                                        <td class="px-4 py-3 text-gray-600"><%= account.branch || '-' %></td>
                                        <td class="px-4 py-3 text-center">
                                            <button onclick='editBankAccount(<%- JSON.stringify(account) %>)' class="bg-blue-500 text-white px-3 py-1 rounded hover:bg-blue-600 transition font-semibold mr-2">
                                                Ubah
                                            </button>
                                            <button onclick='deleteBankAccount(<%= account.id %>)' class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 transition font-semibold">
                                                Hapus
                                            </button>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        window.POS_SETTINGS = <%- JSON.stringify(settings) %>;
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/settings.js"></script>
</body>
</html>
